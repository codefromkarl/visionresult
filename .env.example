# Environment configuration template
# Copy to .env and fill in values

# === Cloudflare ===
VIA_DEPLOY_TOKEN=           # API Token with DNS:Edit + Pages:Edit
VIA_CLOUDFLARE_ACCOUNT_ID=  # Account ID from Cloudflare dashboard
VIA_CLOUDFLARE_ZONE_ID=     # Zone ID for codefromkarl.xyz
VIA_PAGES_PROJECT=vision-insight

# === AI Models ===
# auto: try Zhipu -> OpenAI -> Gemini, then explicit degraded mode if none is available
VIA_VLM_PROVIDER=auto       # auto | zhipu | openai | gemini | qwen2-vl
VIA_ZHIPU_API_KEY=
VIA_OPENAI_API_KEY=
VIA_GEMINI_API_KEY=
VIA_QWEN_MODEL_PATH=

# === OCR ===
# auto/provider fallback keeps pipeline running if one OCR engine is unavailable
VIA_OCR_PROVIDER=baidu       # auto | baidu | tesseract | paddle
VIA_OCR_LANG=ch              # ch | en | japan | ko

# Baidu OCR (required when VIA_OCR_PROVIDER=baidu)
VIA_BAIDU_OCR_API_KEY=
VIA_BAIDU_OCR_SECRET_KEY=
VIA_BAIDU_OCR_ACCURATE=true   # true=high-accuracy, false=standard

# === Database (后期) ===
VIA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vision_insight

# === Search APIs (可选) ===
VIA_GOOGLE_API_KEY=
VIA_GOOGLE_CSE_ID=
VIA_BING_API_KEY=

# === Server ===
VIA_HOST=0.0.0.0
VIA_PORT=8000
VIA_DEBUG=true
VIA_CORS_ORIGINS=["http://localhost:3000","https://imagerecognition.codefromkarl.xyz"]

# === Security ===
# Comma-separated API keys for authentication (leave empty to disable)
VIA_API_KEYS=
# Enable API key authentication (true/false)
VIA_ENABLE_API_KEY_AUTH=false

# === Rate Limiting ===
VIA_RATE_LIMIT_PER_MINUTE=60
VIA_RATE_LIMIT_PER_HOUR=1000
