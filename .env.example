# Environment configuration template
# Copy to .env and fill in values

# API Server
VIA_HOST=0.0.0.0
VIA_PORT=8000
VIA_DEBUG=true
VIA_CORS_ORIGINS=["http://localhost:3000"]

# VLM Provider (qwen2-vl | openai | gemini)
VIA_VLM_PROVIDER=openai
VIA_OPENAI_API_KEY=sk-...
VIA_GEMINI_API_KEY=
VIA_QWEN_MODEL_PATH=

# OCR Language (ch | en | japan | korean)
VIA_OCR_LANG=ch

# Database
VIA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vision_insight

# Search APIs (optional)
VIA_GOOGLE_API_KEY=
VIA_GOOGLE_CSE_ID=
VIA_BING_API_KEY=
