#!/usr/bin/env bash
# ==============================================================================
# Git Pre-Commit Hook вҖ” Visual Insight Agent
# ==============================================================================
# еңЁжҜҸж¬Ў commit еүҚиҝҗиЎҢеҝ«йҖҹжЈҖжҹҘпјҢйҳІжӯўдҪҺзә§й”ҷиҜҜиҝӣе…Ҙд»“еә“гҖӮ
#
# е®үиЈ…ж–№ејҸпјҡ
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
# жҲ–иҖ…пјҡ
#   ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
# ==============================================================================

set -euo pipefail

echo "рҹ”Қ Pre-commit checks..."

ERRORS=0

# в”Җв”Җв”Җ 1. Python иҜӯжі•жЈҖжҹҘпјҲд»…жЈҖжҹҘ staged ж–Үд»¶пјү в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [[ -n "$STAGED_PY" ]]; then
    echo -n "  Python syntax... "
    for f in $STAGED_PY; do
        if [[ -f "$f" ]]; then
            if ! python3 -c "import ast; ast.parse(open('$f').read())" 2>/dev/null; then
                echo "вқҢ Syntax error in $f"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    done
    if [[ "$ERRORS" -eq 0 ]]; then
        echo "вң…"
    fi
fi

# в”Җв”Җв”Җ 2. Ruff lintпјҲеҝ«йҖҹпјү в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

if command -v ruff &>/dev/null; then
    echo -n "  Ruff lint... "
    if ruff check --quiet --diff 2>/dev/null; then
        echo "вң…"
    else
        echo "вқҢ"
        ERRORS=$((ERRORS + 1))
    fi
fi

# в”Җв”Җв”Җ 3. жЈҖжҹҘж•Ҹж„ҹдҝЎжҒҜ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

echo -n "  No secrets... "
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)
if [[ -n "$STAGED_FILES" ]]; then
    # жЈҖжҹҘеёёи§Ғзҡ„еҜҶй’ҘжЁЎејҸ
    SECRET_PATTERNS='sk-[a-zA-Z0-9]{20,}|AIza[a-zA-Z0-9_-]{35}|ghp_[a-zA-Z0-9]{36}|xox[bpas]-[a-zA-Z0-9-]+'
    SECRETS_FOUND=false
    for f in $STAGED_FILES; do
        if [[ -f "$f" ]] && echo "$f" | grep -qE '\.(py|js|ts|html|env)$'; then
            if git diff --cached "$f" | grep -P "$SECRET_PATTERNS" >/dev/null 2>&1; then
                echo "вқҢ Possible secret in $f"
                SECRETS_FOUND=true
                ERRORS=$((ERRORS + 1))
            fi
        fi
    done
    if [[ "$SECRETS_FOUND" == "false" ]]; then
        echo "вң…"
    fi
fi

# в”Җв”Җв”Җ 4. жЈҖжҹҘ .env дёҚиў«жҸҗдәӨ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

echo -n "  No .env files... "
if echo "$STAGED_FILES" | grep -qE '\.env$|\.env\.local$'; then
    echo "вқҢ .env file staged for commit!"
    ERRORS=$((ERRORS + 1))
else
    echo "вң…"
fi

# в”Җв”Җв”Җ 5. жЈҖжҹҘеӨ§ж–Үд»¶ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

echo -n "  No large files... "
LARGE_FOUND=false
for f in $STAGED_FILES; do
    if [[ -f "$f" ]]; then
        FILESIZE=$(wc -c < "$f" 2>/dev/null || echo 0)
        if [[ "$FILESIZE" -gt 1048576 ]]; then  # 1MB
            echo "вҡ пёҸ  $f is $(($FILESIZE / 1024))KB"
            LARGE_FOUND=true
        fi
    fi
done
if [[ "$LARGE_FOUND" == "false" ]]; then
    echo "вң…"
fi

# в”Җв”Җв”Җ з»“жһң в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

echo ""
if [[ "$ERRORS" -gt 0 ]]; then
    echo "вқҢ Pre-commit check failed ($ERRORS error(s))"
    echo "   Fix the issues above and try again."
    echo "   Use 'git commit --no-verify' to bypass (not recommended)."
    exit 1
else
    echo "вң… Pre-commit checks passed"
    exit 0
fi
